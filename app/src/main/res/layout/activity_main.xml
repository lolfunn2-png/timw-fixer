<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6F8FA"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- HEADER SECTION -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_alignParentLeft="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Auto Time Fix"
                    android:textColor="#1D1B20"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="XPOSED MODULE V1.0.2"
                    android:textColor="#49454F"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <ImageView
                android:id="@+id/id_settings_btn"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_alignParentRight="true"
                android:layout_centerInParent="true"
                android:src="@android:drawable/ic_menu_info_details"
                android:contentDescription="Info"
                android:clickable="true"
                android:focusable="true" />
        </RelativeLayout>

        <!-- CURRENT SYSTEM TIME CARD (PURPLE/LAVENDER STYLE) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_clock_card"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CURRENT SYSTEM TIME"
                android:textColor="#4F378B"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/id_clock_time"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="YYYY-MM-DD HH:MM:SS"
                android:textColor="#21005D"
                android:textSize="26sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/id_clock_target"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sync Target: time.google.com"
                android:textColor="#4F378B"
                android:textSize="13sp"
                android:layout_marginTop="6dp" />
        </LinearLayout>

        <!-- HERO STATUS CARD -->
        <LinearLayout
            android:id="@+id/id_hero_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_hero_card_inactive"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/id_hero_icon"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_alignParentLeft="true"
                    android:gravity="center"
                    android:textSize="24sp"
                    android:text="⚠️" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_toRightOf="@id/id_hero_icon"
                    android:layout_marginLeft="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/id_hero_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Xposed Module Inactive"
                        android:textColor="#1D1B20"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/id_hero_desc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Please activate the module in LSPosed or Xposed Installer, and reboot your device to enable automatic system time correction."
                        android:textColor="#49454F"
                        android:textSize="13sp"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </RelativeLayout>

            <!-- BADGES PILL ROW -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp">

                <TextView
                    android:id="@+id/id_hero_badge_boot"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_badge_green"
                    android:text="BOOT READY"
                    android:textColor="#1E8E3E"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:paddingLeft="10dp"
                    android:paddingRight="10dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:layout_marginRight="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_badge_orange"
                    android:text="ROOT REQUIRED"
                    android:textColor="#B06000"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:paddingLeft="10dp"
                    android:paddingRight="10dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- BOOT SEQUENCE CHECKLIST -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_white_card"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BOOT SEQUENCE CHECKLIST"
                android:textColor="#49454F"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <!-- ROW 1 -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_alignParentLeft="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="System Ready Hook"
                        android:textColor="#1D1B20"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/id_checklist_step1_sub"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Boot hook not active"
                        android:textColor="#79747E"
                        android:textSize="12sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/id_checklist_step1_icon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_alignParentRight="true"
                    android:layout_centerInParent="true"
                    android:gravity="center"
                    android:textSize="16sp"
                    android:text="❌" />
            </RelativeLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0" />

            <!-- ROW 2 -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_alignParentLeft="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Network Connectivity"
                        android:textColor="#1D1B20"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/id_checklist_step2_sub"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Checking internet status..."
                        android:textColor="#79747E"
                        android:textSize="12sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/id_checklist_step2_icon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_alignParentRight="true"
                    android:layout_centerInParent="true"
                    android:gravity="center"
                    android:textSize="16sp"
                    android:text="⏳" />
            </RelativeLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0" />

            <!-- ROW 3 -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_alignParentLeft="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="NTP Sync Engine"
                        android:textColor="#1D1B20"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ready for command sync"
                        android:textColor="#79747E"
                        android:textSize="12sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/id_checklist_step3_icon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_alignParentRight="true"
                    android:layout_centerInParent="true"
                    android:gravity="center"
                    android:textSize="16sp"
                    android:text="✔️" />
            </RelativeLayout>
        </LinearLayout>

        <!-- DIAGNOSTICS CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_white_card"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentLeft="true"
                    android:layout_centerVertical="true"
                    android:text="DIAGNOSTICS"
                    android:textColor="#49454F"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/id_diag_refresh"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:layout_alignParentRight="true"
                    android:text="Refresh"
                    android:textSize="11sp"
                    android:background="@drawable/bg_btn_secondary"
                    android:paddingLeft="12dp"
                    android:paddingRight="12dp" />
            </RelativeLayout>

            <!-- DIAGNOSTICS ROW -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="14dp">

                <!-- Internet Column -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Internet State"
                        android:textColor="#79747E"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/id_diag_ip_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Checking..."
                        android:textColor="#1D1B20"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <!-- Ping Latency Column -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ping 8.8.8.8"
                        android:textColor="#79747E"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/id_diag_ping_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="N/A"
                        android:textColor="#1D1B20"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
            </LinearLayout>

            <Button
                android:id="@+id/id_force_sync_btn"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_btn_primary"
                android:text="FORCE SYNC NOW"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- CONFIGURATION CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_white_card"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CONFIGURATION"
                android:textColor="#49454F"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <!-- SERVER FIELD -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NTP Server Address"
                android:textColor="#1D1B20"
                android:textSize="12sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/id_ntp_server"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@drawable/bg_edittext"
                android:text="time.google.com"
                android:inputType="textUri"
                android:textSize="14sp"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="8dp" />

            <!-- PRESETS ROW -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="14dp">

                <Button
                    android:id="@+id/id_preset_google"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_weight="1"
                    android:text="Google"
                    android:textSize="11sp"
                    android:background="@drawable/bg_btn_secondary"
                    android:layout_marginRight="4dp" />

                <Button
                    android:id="@+id/id_preset_pool"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_weight="1"
                    android:text="NTP Pool"
                    android:textSize="11sp"
                    android:background="@drawable/bg_btn_secondary"
                    android:layout_marginLeft="4dp"
                    android:layout_marginRight="4dp" />

                <Button
                    android:id="@+id/id_preset_windows"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_weight="1"
                    android:text="Windows"
                    android:textSize="11sp"
                    android:background="@drawable/bg_btn_secondary"
                    android:layout_marginLeft="4dp" />
            </LinearLayout>

            <!-- MULTIPLE FIELDS ROW -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <!-- BOOT DELAY FIELD -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginRight="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Boot Delay (s)"
                        android:textColor="#1D1B20"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/id_boot_delay"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_edittext"
                        android:text="30"
                        android:inputType="number"
                        android:textSize="14sp"
                        android:paddingLeft="12dp"
                        android:paddingRight="12dp"
                        android:layout_marginTop="6dp" />
                </LinearLayout>

                <!-- RETRY COUNT FIELD -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginLeft="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Max Retries"
                        android:textColor="#1D1B20"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/id_retry_count"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_edittext"
                        android:text="10"
                        android:inputType="number"
                        android:textSize="14sp"
                        android:paddingLeft="12dp"
                        android:paddingRight="12dp"
                        android:layout_marginTop="6dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- NETWORK TIMEOUT FIELD -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Network Ready Timeout (Seconds)"
                android:textColor="#1D1B20"
                android:textSize="12sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/id_net_timeout"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@drawable/bg_edittext"
                android:text="150"
                android:inputType="number"
                android:textSize="14sp"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="16dp" />

            <Button
                android:id="@+id/id_save_config_btn"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_btn_primary"
                android:text="SAVE CONFIGURATION"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- DEBUG LOGS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_terminal_card"
            android:orientation="vertical"
            android:padding="16dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentLeft="true"
                    android:layout_centerVertical="true"
                    android:text="DEBUG LOGS"
                    android:textColor="#A8C7FA"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/id_clear_logs_btn"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:layout_alignParentRight="true"
                    android:text="Clear"
                    android:textSize="11sp"
                    android:background="@drawable/bg_btn_secondary"
                    android:paddingLeft="12dp"
                    android:paddingRight="12dp" />
            </RelativeLayout>

            <!-- SCROLLABLE LOG LIST -->
            <LinearLayout
                android:id="@+id/id_logs_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
